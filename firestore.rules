rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared storefront data document.
    // NOTE: This is intentionally open so browser-only admin can update globally
    // without server-side auth. Tighten this with Firebase Auth for production security.
    match /drop2wave/store {
      allow read, write: if true;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
